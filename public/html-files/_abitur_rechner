<script>
// ─── DATA ───────────────────────────────────────────────────────────────────

const SEMS = ['12/1','12/2','13/1','13/2'];

// subject types
const TYPES = {
  'ea': { label: 'eA', badge: 'ea', locked: true, desc: 'Erhöhtes Anforderungsniveau' },
