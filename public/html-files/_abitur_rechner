  'q12': { label: 'Nur Q12', badge: 'ga', locked: false, desc: 'Nur Q12 (12/1 + 12/2), z.B. PuG' },
  'opt': { label: 'Wahlf.', badge: 'ga', locked: false, desc: 'Wahlfach / freiwillig' }
};

// Default subjects
let subjects = [
  { id: 1,  name: 'Deutsch',               type: 'ea',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 2,  name: 'Mathematik',             type: 'ea',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 3,  name: 'Englisch (Leistungsfach)', type: 'ea',   grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 4,  name: 'Ethik',                  type: 'pf',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 5,  name: 'Physik',                 type: 'pf',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 6,  name: 'Biologie',               type: 'nw',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 7,  name: 'Geschichte',             type: 'ga',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 8,  name: 'Wirtschaft und Recht',   type: 'ga',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 9,  name: 'Politik und Gesellschaft', type: 'q12',  grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 10, name: 'Sport',                  type: 'opt',    grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 11, name: 'Kunst',                  type: 'ga',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 12, name: 'W-Seminar',              type: 'ws',     grades: [null,null,null,null], struck: [false,false,false,false] },
  { id: 13, name: 'Seminararbeit',          type: 'sa',     grades: [null],                struck: [false] },
];

// W-Seminar: only 12/1, 12/2 count as HJL + seminararbeit counts as 2
// Seminararbeit: one grade field, max 30 pts, counts as 2 einbringungen

let pruefungen = [
  { id: 1, name: 'Deutsch',     type: 'schriftlich', score: null },
  { id: 2, name: 'Mathematik',  type: 'schriftlich', score: null },
  { id: 3, name: 'Englisch',    type: 'schriftlich', score: null },
  { id: 4, name: 'Ethik',       type: 'mündlich',    score: null },
  { id: 5, name: 'Physik',      type: 'mündlich',    score: null },
];

let nextId = 20;

// ─── GRADE TABLE ─────────────────────────────────────────────────────────────

const gradeTable = [
  [900,823,'1,0'],[822,805,'1,1'],[804,787,'1,2'],[786,769,'1,3'],[768,751,'1,4'],
  [750,733,'1,5'],[732,715,'1,6'],[714,697,'1,7'],[696,679,'1,8'],[678,661,'1,9'],
  [660,643,'2,0'],[642,625,'2,1'],[624,607,'2,2'],[606,589,'2,3'],[588,571,'2,4'],
  [570,553,'2,5'],[552,535,'2,6'],[534,517,'2,7'],[516,499,'2,8'],[498,481,'2,9'],
  [480,463,'3,0'],[462,445,'3,1'],[444,427,'3,2'],[426,409,'3,3'],[408,391,'3,4'],
  [390,373,'3,5'],[372,355,'3,6'],[354,337,'3,7'],[336,319,'3,8'],[318,301,'3,9'],
  [300,300,'4,0']
];

function getGrade(pts) {
  if (pts < 300) return null;
  for (const [hi, lo, g] of gradeTable) {
    if (pts >= lo && pts <= hi) return g;
  }
  return null;
}

// ─── RENDER ──────────────────────────────────────────────────────────────────

function isLocked(subject, semIdx) {
  const t = subject.type;
  if (t === 'ea' || t === 'pf') return true; // all 4 locked
  if (t === 'sa') return true;
  if (t === 'ws') return false; // can't strike W-Seminar HJ in UI but they're already limited
  if (t === 'fs' || t === 'nw') return false; // can't reduce below 4 total — handled in validation
  return false;
}

function renderSubjects() {
  const tbody = document.getElementById('subjects-tbody');
  tbody.innerHTML = '';

  for (const sub of subjects) {
    if (sub.type === 'ws') {
      renderWSeminarRow(tbody, sub);
    } else if (sub.type === 'sa') {
      renderSeminararbeitRow(tbody, sub);
    } else if (sub.type === 'q12') {
      renderQ12Row(tbody, sub);
    } else {
      renderNormalRow(tbody, sub);
    }
  }
}

function renderNormalRow(tbody, sub) {
  const tr = document.createElement('tr');
  tr.className = 'subject-row';
  tr.setAttribute('data-id', sub.id);

  const typeInfo = TYPES[sub.type] || TYPES['ga'];
  const locked = (sub.type === 'ea' || sub.type === 'pf');

  // Name cell
  let nameTd = `<td class="subject-name-cell">
    <div class="subject-name-wrapper">
      <input class="subject-name-input" value="${sub.name}" onchange="updateSubjectName(${sub.id}, this.value)" title="Klick zum Umbenennen">
      <span class="badge ${typeInfo.badge}">${typeInfo.label}</span>
    </div>
  </td>`;

  // Type select
  let typeTd = `<td style="padding:0 8px">
    <select class="type-select" onchange="updateSubjectType(${sub.id}, this.value)" title="Fachtyp">`;
  for (const [k,v] of Object.entries(TYPES)) {
    if (k === 'ws' || k === 'sa') continue;
    typeTd += `<option value="${k}" ${sub.type===k?'selected':''}>${v.desc}</option>`;
  }
  typeTd += `</select></td>`;

  // Grade cells
  let gradeTds = '';
  for (let i = 0; i < 4; i++) {
    const val = sub.grades[i];
    const str = sub.struck[i];
    const cellLocked = locked;
    const is132 = i === 3;

    gradeTds += `<td class="grade-cell${cellLocked?' locked':''}" style="${is132?'background:rgba(245,158,11,0.03)':''}">
      <div class="grade-input-wrap">
        <input class="grade-input${val!==null?' has-value':''}${str?' struck':''}"
          type="number" min="0" max="15" step="1"
          value="${val!==null?val:''}"
          placeholder="—"
          onchange="updateGrade(${sub.id},${i},this.value)"
          title="Note 0–15 Punkte">
        ${!cellLocked ? `<button class="strike-btn${str?' active':''}" onclick="toggleStrike(${sub.id},${i})" title="Ausstreichen / Wieder einbringen">✕</button>` : `<span class="cell-lock" title="Pflichteinbringung">🔒</span>`}
      </div>
    </td>`;
  }

  // Row total
  const rowTotal = calcSubjectTotal(sub);
  const rowTotalTd = `<td class="row-total-cell"><span class="row-total${rowTotal>0?' has-data':''}">${rowTotal > 0 ? rowTotal : '—'}</span></td>`;

  // Delete
  const delTd = `<td class="action-col"><button class="del-row-btn" onclick="deleteSubject(${sub.id})" title="Fach entfernen">×</button></td>`;

  tr.innerHTML = nameTd + typeTd + gradeTds + rowTotalTd + delTd;
  tbody.appendChild(tr);
}

function renderQ12Row(tbody, sub) {
  const tr = document.createElement('tr');
  tr.className = 'subject-row';
  tr.setAttribute('data-id', sub.id);

  let html = `<td class="subject-name-cell">
    <div class="subject-name-wrapper">
      <input class="subject-name-input" value="${sub.name}" onchange="updateSubjectName(${sub.id}, this.value)">
      <span class="badge ga">Nur Q12</span>
    </div>
  </td>
  <td style="padding:0 8px"><span style="font-family:var(--mono);font-size:10px;color:var(--text-muted)">Q12 only</span></td>`;

  for (let i = 0; i < 4; i++) {
    if (i >= 2) {
      html += `<td class="grade-cell" style="background:rgba(0,0,0,0.2)">
        <span style="font-family:var(--mono);font-size:10px;color:var(--text-muted)" title="Dieses Fach wird nur in Q12 belegt">—</span>
      </td>`;
      continue;
    }
    const val = sub.grades[i];
    const str = sub.struck[i];
    html += `<td class="grade-cell">
      <div class="grade-input-wrap">
        <input class="grade-input${val!==null?' has-value':''}${str?' struck':''}"
          type="number" min="0" max="15"
          value="${val!==null?val:''}"
          placeholder="—"
          onchange="updateGrade(${sub.id},${i},this.value)">
        <button class="strike-btn${str?' active':''}" onclick="toggleStrike(${sub.id},${i})" title="Ausstreichen">✕</button>
      </div>
    </td>`;
  }

  const rowTotal = calcSubjectTotal(sub);
  html += `<td class="row-total-cell"><span class="row-total${rowTotal>0?' has-data':''}">${rowTotal>0?rowTotal:'—'}</span></td>`;
  html += `<td class="action-col"><button class="del-row-btn" onclick="deleteSubject(${sub.id})">×</button></td>`;
  tr.innerHTML = html;
  tbody.appendChild(tr);
}

function renderWSeminarRow(tbody, sub) {
  const tr = document.createElement('tr');
  tr.className = 'subject-row wseminar-row';
  tr.setAttribute('data-id', sub.id);

  let html = `<td class="subject-name-cell">
    <div class="subject-name-wrapper">
      <input class="subject-name-input" value="${sub.name}" onchange="updateSubjectName(${sub.id}, this.value)">
      <span class="badge ws">W-Seminar</span>
    </div>
  </td>
  <td style="padding:0 8px"><span style="font-family:var(--mono);font-size:10px;color:var(--text-muted)">Sonderregel</span></td>`;

  // Only 12/1 and 12/2 for W-Seminar
  for (let i = 0; i < 4; i++) {
    if (i >= 2) {
      html += `<td class="grade-cell" style="background:rgba(0,0,0,0.2)">
        <span style="font-family:var(--mono);font-size:10px;color:var(--text-muted)">—</span>
      </td>`;
      continue;
    }
    const val = sub.grades[i];
    const str = sub.struck[i];
    html += `<td class="grade-cell">
      <div class="grade-input-wrap">
        <input class="grade-input${val!==null?' has-value':''}${str?' struck':''}"
          type="number" min="0" max="15"
          value="${val!==null?val:''}"
          placeholder="—"
          onchange="updateGrade(${sub.id},${i},this.value)">
        <button class="strike-btn${str?' active':''}" onclick="toggleStrike(${sub.id},${i})" title="Ausstreichen">✕</button>
      </div>
    </td>`;
  }

  const rowTotal = calcSubjectTotal(sub);
  html += `<td class="row-total-cell"><span class="row-total${rowTotal>0?' has-data':''}">${rowTotal>0?rowTotal:'—'}</span></td>`;
  html += `<td class="action-col"><button class="del-row-btn" onclick="deleteSubject(${sub.id})">×</button></td>`;

  tr.innerHTML = html;
  tbody.appendChild(tr);
}

function renderSeminararbeitRow(tbody, sub) {
  const tr = document.createElement('tr');
  tr.className = 'subject-row seminararbeit-row';
  tr.setAttribute('data-id', sub.id);

  const val = sub.grades[0];

  let html = `<td class="subject-name-cell">
    <div class="subject-name-wrapper">
      <input class="subject-name-input" value="${sub.name}" onchange="updateSubjectName(${sub.id}, this.value)">
      <span class="badge ws">Seminararbeit</span>
    </div>
  </td>
  <td style="padding:0 8px"><span style="font-family:var(--mono);font-size:10px;color:var(--text-muted)">max. 30 Pkt, zählt 2×</span></td>
  <td class="grade-cell" colspan="4" style="text-align:left;padding-left:24px">
    <div style="display:flex;align-items:center;gap:12px">
      <input class="seminar-input${val!==null?' has-value':''}"
        type="number" min="0" max="30"
        value="${val!==null?val:''}"
        placeholder="0–30"
        onchange="updateSeminarGrade(${sub.id},this.value)">
      <span style="font-family:var(--mono);font-size:11px;color:var(--text-muted)">Punkte (Arbeit 3×, Präsentation 1× → Durchschnitt)</span>
    </div>
  </td>
  <td class="row-total-cell"><span class="row-total${val!==null?' has-data':''}" id="sa-total">${val!==null ? '2×'+val : '—'}</span></td>
  <td class="action-col"></td>`;

  tr.innerHTML = html;
  tbody.appendChild(tr);
}

function renderPruefungen() {
  const grid = document.getElementById('block2-grid');
  grid.innerHTML = '';
  pruefungen.forEach((p, idx) => {
    const card = document.createElement('div');
    card.className = 'pruefung-card';
    const pts4 = p.score !== null ? p.score * 4 : null;

    card.innerHTML = `
      <div class="pruefung-num">${idx+1}</div>
      <div class="pruefung-label">Prüfung ${idx+1}</div>
      <input class="pruefung-name-input" value="${p.name}" placeholder="Fachname" onchange="updatePruefungName(${p.id},this.value)">
      <div class="pruefung-type-row">
        <span class="type-pill schriftlich${p.type==='schriftlich'?' active':''}" onclick="setPruefungType(${p.id},'schriftlich',this)">schriftlich</span>
        <span class="type-pill muendlich${p.type==='mündlich'?' active':''}" onclick="setPruefungType(${p.id},'mündlich',this)">mündlich</span>
      </div>
      <div class="pruefung-score-row">
        <input class="pruefung-score-input" type="number" min="0" max="15"
          value="${p.score!==null?p.score:''}"
          placeholder="0–15"
          onchange="updatePruefungScore(${p.id},this.value)"
          title="Ergebnis in Punkte (0–15)">
        <div>
          <div class="pruefung-calc">× 4 =</div>
          <div class="pruefung-result${pts4!==null?' has-val':''}">${pts4!==null?pts4:'—'}</div>
        </div>
      </div>`;
    grid.appendChild(card);
  });
}

// ─── MUTATIONS ───────────────────────────────────────────────────────────────

function updateSubjectName(id, val) {
  const s = subjects.find(x=>x.id===id);
  if (s) s.name = val;
  recalc();
}

function updateSubjectType(id, type) {
  const s = subjects.find(x=>x.id===id);
  if (!s) return;
  s.type = type;
  renderSubjects();
  recalc();
}

function updateGrade(id, semIdx, val) {
  const s = subjects.find(x=>x.id===id);
  if (!s) return;
  const n = val === '' ? null : Math.min(15, Math.max(0, parseInt(val)));
  s.grades[semIdx] = n;
  if (n === null) s.struck[semIdx] = false;
  renderSubjects();
  recalc();
}

function updateSeminarGrade(id, val) {
  const s = subjects.find(x=>x.id===id);
  if (!s) return;
  s.grades[0] = val === '' ? null : Math.min(30, Math.max(0, parseInt(val)));
  renderSubjects();
  recalc();
}

function toggleStrike(id, semIdx) {
  const s = subjects.find(x=>x.id===id);
  if (!s) return;
  if (s.grades[semIdx] === null) return; // can't strike empty
  s.struck[semIdx] = !s.struck[semIdx];
  renderSubjects();
  recalc();
}

function updatePruefungName(id, val) {
  const p = pruefungen.find(x=>x.id===id);
  if (p) p.name = val;
  recalc();
}

function setPruefungType(id, type, el) {
  const p = pruefungen.find(x=>x.id===id);
  if (!p) return;
  p.type = type;
  const card = el.closest('.pruefung-card');
  card.querySelectorAll('.type-pill').forEach(pill => {
    pill.classList.remove('active');
    if (pill.classList.contains(type)) pill.classList.add('active');
  });
  recalc();
}

function updatePruefungScore(id, val) {
  const p = pruefungen.find(x=>x.id===id);
  if (!p) return;
  p.score = val === '' ? null : Math.min(15, Math.max(0, parseInt(val)));
  renderPruefungen();
  recalc();
}

function addSubject() {
  subjects.push({
    id: nextId++,
    name: 'Neues Fach',
    type: 'ga',
    grades: [null,null,null,null],
    struck: [false,false,false,false]
  });
  renderSubjects();
  recalc();
}

function deleteSubject(id) {
  subjects = subjects.filter(x=>x.id!==id);
  renderSubjects();
  recalc();
}

// ─── CALC ─────────────────────────────────────────────────────────────────────

function calcSubjectTotal(sub) {
  if (sub.type === 'sa') {
    return sub.grades[0] !== null ? sub.grades[0] : 0;
  }
  if (sub.type === 'ws' || sub.type === 'q12') {
    let t = 0;
    for (let i = 0; i < 2; i++) {
      if (sub.grades[i] !== null && !sub.struck[i]) t += sub.grades[i];
    }
    return t;
  }
  let t = 0;
  for (let i = 0; i < 4; i++) {
    if (sub.grades[i] !== null && !sub.struck[i]) t += sub.grades[i];
  }
  return t;
}

function calcEinbringungen() {
  let count = 0;
  for (const sub of subjects) {
    if (sub.type === 'sa') {
      if (sub.grades[0] !== null) count += 2;
      continue;
    }
    if (sub.type === 'ws' || sub.type === 'q12') {
      for (let i = 0; i < 2; i++) {
        if (sub.grades[i] !== null && !sub.struck[i]) count++;
      }
      continue;
    }
    for (let i = 0; i < 4; i++) {
      if (sub.grades[i] !== null && !sub.struck[i]) count++;
    }
  }
  return count;
}

function calcBlock1() {
  let sum = 0;
  for (const sub of subjects) {
    if (sub.type === 'sa') {
      if (sub.grades[0] !== null) sum += sub.grades[0];
      continue;
    }
    if (sub.type === 'ws' || sub.type === 'q12') {
      for (let i = 0; i < 2; i++) {
        if (sub.grades[i] !== null && !sub.struck[i]) sum += sub.grades[i];
      }
      continue;
    }
    for (let i = 0; i < 4; i++) {
      if (sub.grades[i] !== null && !sub.struck[i]) sum += sub.grades[i];
    }
  }
  return sum;
}

function calcBlock2() {
  let sum = 0;
  for (const p of pruefungen) {
    if (p.score !== null) sum += p.score * 4;
  }
  return sum;
}

function recalc() {
  const b1 = calcBlock1();
  const b2 = calcBlock2();
  const total = b1 + b2;
  const einbring = calcEinbringungen();

  // Update einbringungen counter
  const elLabel = document.getElementById('einbring-label');
  const elFill = document.getElementById('einbring-fill');
  elLabel.textContent = `${einbring} / 40`;
  elLabel.className = 'einbring-label' + (einbring > 40 ? ' over' : '');
  const pct = Math.min(100, (einbring / 40) * 100);
  elFill.style.width = pct + '%';
  elFill.className = 'einbring-fill' + (einbring > 40 ? ' over' : '');

  // Warnings
  const warn = document.getElementById('warning-banner');
  if (einbring > 40) {
    warn.textContent = `⚠ Du hast ${einbring} Einbringungen — das Maximum sind 40. Bitte streiche noch ${einbring-40} Halbjahresleistung(en) aus.`;
    warn.className = 'warning-banner show';
  } else {
    warn.className = 'warning-banner';
  }

  // Block I
  document.getElementById('block1-sum').textContent = `Summe: ${b1} / 600`;

  // Block II
  document.getElementById('block2-sum').textContent = `Summe: ${b2} / 300`;

  // Results
  const resB1 = document.getElementById('res-b1');
  const resB2 = document.getElementById('res-b2');
  const resTotal = document.getElementById('res-total');
  const resGrade = document.getElementById('res-grade');
  const failHint = document.getElementById('fail-hint');
  const resRange = document.getElementById('res-range');
  const meterFill = document.getElementById('meter-fill');

  resB1.textContent = b1;
  resB1.className = 'num' + (b1 > 0 ? ' active' : '');
  resB2.textContent = b2;
  resB2.className = 'num' + (b2 > 0 ? ' active' : '');
  resTotal.textContent = total;
  resTotal.className = 'num' + (total > 0 ? ' active' : '');

  // Meter: 300 = pass threshold, map 300-900 to 0-100%
  const meterPct = total < 300 ? (total / 300 * 33) : 33 + ((total - 300) / 600 * 67);
  meterFill.style.width = Math.min(100, Math.max(0, meterPct)) + '%';

  // Grade
  if (total === 0) {
    resGrade.textContent = '—';
    resGrade.className = 'final-grade pending';
    failHint.style.display = 'none';
    resRange.textContent = '';
  } else if (total < 300) {
    resGrade.textContent = 'N.B.';
    resGrade.className = 'final-grade fail';
    failHint.style.display = 'block';
    resRange.textContent = `${300 - total} Punkte fehlen zum Bestehen`;
  } else {
    const grade = getGrade(total);
    resGrade.textContent = grade || '—';
    resGrade.className = 'final-grade pass';
    failHint.style.display = 'none';
    resRange.textContent = `${900 - total} Punkte bis zur Note 1,0`;
  }

  // Notenberater
  renderNotenberater(b1, b2);
}

// ─── DEFAULT DATA ─────────────────────────────────────────────────────────────

const DEFAULT_GRADES = {
  1:  [7,  10, 10, null],
  2:  [11, 9,  9,  null],
  3:  [10, 14, 13, null],
  4:  [9,  15, 10, null],
  5:  [11, 9,  11, null],
  6:  [8,  8,  8,  null],
  7:  [9,  9,  9,  null],
  8:  [7,  8,  8,  null],
  9:  [11, 8,  null, null],
  10: [9,  15, 13, null],
  11: [9,  12, 12, null],
  12: [10, 11, null, null],
};

function loadDefaults() {
  for (const sub of subjects) {
    if (sub.type === 'sa') continue;
    const def = DEFAULT_GRADES[sub.id];
    if (!def) continue;
    sub.grades = [...def];
    sub.struck = sub.grades.map(() => false);
  }
  renderSubjects();
  recalc();
}

// ─── AUTO-STRIKE ──────────────────────────────────────────────────────────────

function autoStrike() {
  // First reset all non-locked strikes
  for (const sub of subjects) {
    if (sub.type === 'sa' || sub.type === 'ea' || sub.type === 'pf') continue;
    sub.struck = sub.struck.map(() => false);
  }

  // Build list of strikeable slots: { subId, semIdx, value }
  // Rules:
  // - ea, pf: never strikeable
  // - sa: never
  // - nw/fs: need to keep at least 4 entries total across all nw / all fs
  // - ws, q12: can strike either of their 2 slots
  // - ga, opt: can strike any slot with a value

  let strikeable = [];

  for (const sub of subjects) {
    const t = sub.type;
    if (t === 'ea' || t === 'pf' || t === 'sa') continue;
    const maxSem = (t === 'ws' || t === 'q12') ? 2 : 4;
    for (let i = 0; i < maxSem; i++) {
      if (sub.grades[i] !== null) {
        strikeable.push({ subId: sub.id, semIdx: i, value: sub.grades[i], type: t });
      }
    }
  }

  // Sort ascending (worst first = lowest points)
  strikeable.sort((a, b) => a.value - b.value);

  // Strike until einbringungen <= 40, respecting nw/fs min-4 constraint
  let safety = 0;
  while (calcEinbringungen() > 40 && safety < 50) {
    safety++;
    let struck = false;
    for (const slot of strikeable) {
      const sub = subjects.find(x => x.id === slot.subId);
      if (!sub || sub.struck[slot.semIdx]) continue;

      // Check fs/nw constraint: after striking, still >=4 total for that type?
      if (slot.type === 'fs' || slot.type === 'nw') {
        const sametype = subjects.filter(x => x.type === slot.type);
        let countAfter = 0;
        for (const s of sametype) {
          for (let i = 0; i < 4; i++) {
            if (s.grades[i] !== null) {
              const wouldBeStruck = (s.id === slot.subId && i === slot.semIdx) ? true : s.struck[i];
              if (!wouldBeStruck) countAfter++;
            }
          }
        }
        if (countAfter < 4) continue;
      }

      sub.struck[slot.semIdx] = true;
      struck = true;
      break;
    }
    if (!struck) break;
  }

  renderSubjects();
  recalc();
}

function resetStrikes() {
  for (const sub of subjects) {
    sub.struck = sub.struck.map(() => false);
  }
  renderSubjects();
  recalc();
}

// ─── NOTENBERATER ─────────────────────────────────────────────────────────────

function renderNotenberater(b1, b2) {
  const grid = document.getElementById('notenberater-grid');
  const meta = document.getElementById('nb-meta');
  if (!grid) return;

  const b2Current = b2;
  const b2Max = 300;
  const totalCurrent = b1 + b2Current;
  const currentGrade = getGrade(totalCurrent);

  meta.textContent = `Block I: ${b1} Pkt  |  Block II aktuell: ${b2Current} Pkt  |  Gesamt: ${totalCurrent} Pkt`;

  grid.innerHTML = '';

  for (const [hi, lo, note] of gradeTable) {
    const needed = lo; // minimum total for this grade
    const b2Needed = needed - b1; // how much Block II still needed
    const b2Still = b2Needed - b2Current; // still missing from Block II
    const perExam = b2Needed / 5 / 4; // avg raw score (0-15) per exam to get b2Needed

    let status;
    if (totalCurrent >= lo) status = 'achieved';
    else if (b2Needed <= b2Max) status = 'possible';
    else status = 'impossible';

    if (note === currentGrade && totalCurrent >= 300) status = 'current';

    const card = document.createElement('div');
    card.className = `nb-card ${status}`;

    const pct = Math.min(100, Math.max(0, (totalCurrent / lo) * 100));
    const perExamRaw = Math.max(0, b2Still / 5 / 4); // avg still needed per exam (raw 0-15)
    const perExamTotal = Math.max(0, Math.ceil(b2Needed / 5)); // total pts per exam incl ×4

    let b2Label, perFachLabel;
    if (status === 'achieved') {
      b2Label = '✓ erreicht';
      perFachLabel = '';
    } else if (status === 'impossible') {
      b2Label = 'Nicht möglich';
      perFachLabel = `Block II bräuchte ${b2Needed} Pkt`;
    } else {
      const stillNeeded = Math.max(0, b2Needed - b2Current);
      b2Label = stillNeeded > 0 ? `noch ${stillNeeded} Pkt in B2` : '✓ fast da';
      const avgPerExam = (b2Needed - b2Current) / 5 / 4;
      const avgFmt = avgPerExam <= 0 ? '—' : avgPerExam.toFixed(1);
      perFachLabel = `Ø ${avgFmt} / 15 pro Prüfung`;
    }

    card.innerHTML = `
      <div class="nb-status-dot"></div>
      <div class="nb-note">${note}</div>
      <div class="nb-needed">Min. ${lo} Punkte gesamt</div>
      <div class="nb-b2-needed">${b2Label}</div>
      <div class="nb-per-fach">${perFachLabel}</div>
      <div class="nb-bar"><div class="nb-bar-fill" style="width:${pct}%"></div></div>
      <div class="nb-b2-note">${pct >= 100 ? '100%' : pct.toFixed(0) + '% erreicht'}</div>
    `;
    grid.appendChild(card);
  }
}

