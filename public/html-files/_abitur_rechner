<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Abiturnotenrechner — Bayern G9</title>
<link href="https://fonts.googleapis.com/css2?family=Courier+Prime:ital,wght@0,400;0,700;1,400&family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0e0f11;
  --bg2: #16181c;
  --bg3: #1e2128;
  --border: #2e3038;
  --border2: #3d4049;
  --amber: #f59e0b;
  --amber-dim: #b45309;
  --amber-glow: rgba(245,158,11,0.12);
  --red: #ef4444;
  --green: #22c55e;
  --text: #e8e9ec;
  --text-dim: #7c7f88;
  --text-muted: #4a4d57;
  --mono: 'Courier Prime', monospace;
  --sans: 'DM Sans', sans-serif;
  --display: 'Bebas Neue', sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-size: 14px;
  line-height: 1.5;
  min-height: 100vh;
  background-image:
    linear-gradient(rgba(245,158,11,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245,158,11,0.02) 1px, transparent 1px);
  background-size: 40px 40px;
}

header {
  border-bottom: 1px solid var(--border);
  padding: 24px 40px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20px;
  background: var(--bg);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left h1 {
  font-family: var(--display);
  font-size: 32px;
  letter-spacing: 2px;
  color: var(--amber);
  line-height: 1;
}

.header-left p {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-dim);
  margin-top: 4px;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.score-display {
  display: flex;
  gap: 24px;
  align-items: center;
}

.score-block {
  text-align: right;
}

.score-block .label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.score-block .value {
  font-family: var(--display);
  font-size: 28px;
  letter-spacing: 1px;
  color: var(--text);
  line-height: 1;
}

.score-block .value.grade {
  color: var(--amber);
  font-size: 36px;
}

.score-block .value.fail { color: var(--red); }
.score-block .value.good { color: var(--green); }

.score-sep {
  width: 1px;
  height: 40px;
  background: var(--border);
}

main {
  max-width: 1400px;
  margin: 0 auto;
  padding: 32px 40px;
  display: flex;
  flex-direction: column;
  gap: 40px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.section-title {
  font-family: var(--display);
  font-size: 20px;
  letter-spacing: 2px;
  color: var(--amber);
  display: flex;
  align-items: center;
  gap: 12px;
}

.section-title .tag {
  font-family: var(--mono);
  font-size: 10px;
  background: var(--amber-glow);
  border: 1px solid var(--amber-dim);
  color: var(--amber);
  padding: 2px 8px;
  letter-spacing: 1px;
}

.section-meta {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-dim);
}

/* BLOCK I TABLE */
.block1-table {
  width: 100%;
  border-collapse: collapse;
  border: 1px solid var(--border);
}

.block1-table th {
  font-family: var(--mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-muted);
  padding: 10px 12px;
  text-align: left;
  background: var(--bg2);
  border-bottom: 1px solid var(--border);
  white-space: nowrap;
}

.block1-table th.sem-col {
  text-align: center;
  min-width: 80px;
}

.block1-table th.total-col {
  text-align: center;
  color: var(--amber-dim);
  min-width: 70px;
}

.block1-table th.action-col {
  width: 40px;
  text-align: center;
}

.block1-table td {
  padding: 0;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}

.block1-table tr:hover td {
  background: rgba(245,158,11,0.02);
}

.block1-table tr.subject-row td { height: 48px; }

/* Subject name cell */
.subject-name-cell {
  padding: 0 12px;
  min-width: 200px;
}

.subject-name-wrapper {
  display: flex;
  align-items: center;
  gap: 8px;
}

.subject-name-input {
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  width: 140px;
  cursor: pointer;
}

.subject-name-input:focus {
  color: var(--amber);
  border-bottom: 1px solid var(--amber-dim);
}

.subject-badges {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
}

.badge {
  font-family: var(--mono);
  font-size: 9px;
  padding: 1px 5px;
  border-radius: 2px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  white-space: nowrap;
}
.badge.ea { background: rgba(245,158,11,0.15); color: var(--amber); border: 1px solid var(--amber-dim); }
.badge.ga { background: rgba(100,100,120,0.2); color: #888; border: 1px solid #444; }
.badge.pf { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid #166534; }
.badge.ws { background: rgba(139,92,246,0.15); color: #a78bfa; border: 1px solid #4c1d95; }
.badge.lf { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid #1e3a5f; }

/* Grade cell */
.grade-cell {
  text-align: center;
  padding: 8px 4px;
  position: relative;
}

.grade-input-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.grade-input {
  width: 52px;
  height: 34px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 3px;
  color: var(--text);
  font-family: var(--mono);
  font-size: 15px;
  font-weight: 700;
  text-align: center;
  outline: none;
  transition: border-color 0.15s, background 0.15s;
  -moz-appearance: textfield;
}
.grade-input::-webkit-inner-spin-button,
.grade-input::-webkit-outer-spin-button { -webkit-appearance: none; }

.grade-input:focus {
  border-color: var(--amber-dim);
  background: var(--bg2);
}

.grade-input.has-value {
  border-color: var(--border2);
  color: var(--amber);
}

.grade-input.struck {
  color: var(--text-muted) !important;
  text-decoration: line-through;
  background: var(--bg2);
  border-color: var(--border) !important;
  border-style: dashed !important;
}

.strike-btn {
  position: absolute;
  right: -18px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
  font-size: 10px;
  padding: 2px;
  opacity: 0;
  transition: opacity 0.15s, color 0.15s;
  line-height: 1;
}

.grade-cell:hover .strike-btn { opacity: 1; }
.strike-btn:hover { color: var(--red); }
.strike-btn.active { color: var(--red); opacity: 0.7; }

.grade-cell.locked .strike-btn { display: none; }
.grade-cell.locked .grade-input.has-value {
  border-color: rgba(245,158,11,0.3);
}

.cell-lock {
  font-size: 9px;
  color: var(--text-muted);
  position: absolute;
  top: 3px;
  right: 3px;
}

/* Row total */
.row-total-cell {
  text-align: center;
  padding: 0 8px;
}

.row-total {
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 700;
  color: var(--text-dim);
}

.row-total.has-data { color: var(--amber); }

/* Delete row */
.del-row-btn {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
  font-size: 14px;
  padding: 8px;
  opacity: 0;
  transition: opacity 0.15s, color 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.block1-table tr:hover .del-row-btn { opacity: 1; }
.del-row-btn:hover { color: var(--red); }

/* W-Seminar special row */
.wseminar-row td { background: rgba(139,92,246,0.04); }

/* Seminararbeit row */
.seminararbeit-row td { background: rgba(139,92,246,0.07); }

.seminar-input {
  width: 70px;
  height: 34px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 3px;
  color: var(--text);
  font-family: var(--mono);
  font-size: 15px;
  font-weight: 700;
  text-align: center;
  outline: none;
  -moz-appearance: textfield;
}
.seminar-input::-webkit-inner-spin-button,
.seminar-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.seminar-input:focus { border-color: #7c3aed; }
.seminar-input.has-value { color: #a78bfa; border-color: #4c1d95; }

/* Footer row */
.table-footer td {
  padding: 10px 12px;
  background: var(--bg2);
  border-top: 1px solid var(--border);
}

.add-row-btn {
  background: none;
  border: 1px dashed var(--border2);
  color: var(--text-dim);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  padding: 6px 14px;
  cursor: pointer;
  transition: border-color 0.15s, color 0.15s;
}
.add-row-btn:hover { border-color: var(--amber-dim); color: var(--amber); }

/* Einbringungen counter */
.einbring-counter {
  display: flex;
  align-items: center;
  gap: 8px;
}

.einbring-bar {
  width: 200px;
  height: 6px;
  background: var(--bg3);
  border-radius: 3px;
  overflow: hidden;
  border: 1px solid var(--border);
}

.einbring-fill {
  height: 100%;
  background: var(--amber);
  border-radius: 3px;
  transition: width 0.3s;
}
.einbring-fill.over { background: var(--red); }

.einbring-label {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-dim);
  min-width: 60px;
}
.einbring-label.over { color: var(--red); }

/* Type selector */
.type-select {
  background: var(--bg2);
  border: 1px solid var(--border);
  color: var(--text-dim);
  font-family: var(--mono);
  font-size: 10px;
  padding: 2px 4px;
  cursor: pointer;
  outline: none;
  border-radius: 2px;
}
.type-select:focus { border-color: var(--amber-dim); }

/* BLOCK II */
.block2-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16px;
}

.pruefung-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 20px;
  position: relative;
  transition: border-color 0.2s;
}
.pruefung-card:hover { border-color: var(--border2); }

.pruefung-num {
  font-family: var(--display);
  font-size: 48px;
  color: var(--bg3);
  position: absolute;
  right: 12px;
  top: 8px;
  line-height: 1;
  user-select: none;
  pointer-events: none;
}

.pruefung-label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 8px;
}

.pruefung-name-input {
  background: transparent;
  border: none;
  border-bottom: 1px solid var(--border);
  outline: none;
  color: var(--text);
  font-family: var(--sans);
  font-size: 13px;
  font-weight: 500;
  width: 100%;
  padding: 2px 0;
  margin-bottom: 12px;
  transition: border-color 0.15s;
}
.pruefung-name-input:focus { border-color: var(--amber-dim); color: var(--amber); }

.pruefung-type-row {
  display: flex;
  gap: 6px;
  margin-bottom: 14px;
}

.type-pill {
  font-family: var(--mono);
  font-size: 9px;
  padding: 2px 8px;
  border-radius: 2px;
  border: 1px solid var(--border);
  cursor: pointer;
  color: var(--text-muted);
  transition: all 0.15s;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.type-pill.active.schriftlich { border-color: var(--amber-dim); background: var(--amber-glow); color: var(--amber); }
.type-pill.active.muendlich { border-color: #166534; background: rgba(34,197,94,0.1); color: #4ade80; }

.pruefung-score-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.pruefung-score-input {
  width: 60px;
  height: 42px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 3px;
  color: var(--amber);
  font-family: var(--mono);
  font-size: 22px;
  font-weight: 700;
  text-align: center;
  outline: none;
  -moz-appearance: textfield;
}
.pruefung-score-input::-webkit-inner-spin-button,
.pruefung-score-input::-webkit-outer-spin-button { -webkit-appearance: none; }
.pruefung-score-input:focus { border-color: var(--amber); }

.pruefung-calc {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-muted);
}

.pruefung-result {
  font-family: var(--display);
  font-size: 22px;
  color: var(--text-dim);
  line-height: 1;
}
.pruefung-result.has-val { color: var(--amber); }

/* RESULTS */
.results-panel {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 32px;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 2fr;
  gap: 32px;
  align-items: center;
}

.result-item .label {
  font-family: var(--mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text-muted);
  margin-bottom: 4px;
}

.result-item .num {
  font-family: var(--display);
  font-size: 40px;
  letter-spacing: 1px;
  color: var(--text-dim);
  line-height: 1;
}
.result-item .num.active { color: var(--amber); }
.result-item .num.fail-color { color: var(--red); }
.result-item .num.pass-color { color: var(--green); }

.result-item .sub {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-muted);
  margin-top: 2px;
}

.grade-meter {
  position: relative;
}

.grade-meter-bar {
  height: 8px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
  margin-top: 8px;
}

.grade-meter-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--amber), #fbbf24);
  border-radius: 4px;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.grade-meter-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
}
.grade-meter-labels span {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text-muted);
}

.final-grade {
  font-family: var(--display);
  font-size: 72px;
  letter-spacing: 2px;
  line-height: 1;
  margin-top: 4px;
}
.final-grade.pending { color: var(--text-muted); }
.final-grade.pass { color: var(--amber); }
.final-grade.fail { color: var(--red); }

.nicht-bestanden-hint {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--red);
  margin-top: 4px;
}

/* Tooltip / info */
.info-row {
  display: flex;
  gap: 24px;
  align-items: center;
  padding: 12px 16px;
  background: var(--bg2);
  border: 1px solid var(--border);
  font-family: var(--mono);
  font-size: 11px;
  color: var(--text-dim);
}

.info-item { display: flex; align-items: center; gap: 6px; }
.info-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--amber); }
.info-dot.red { background: var(--red); }
.info-dot.purple { background: #a78bfa; }
.info-dot.green { background: #4ade80; }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 3px; }

/* Responsive */
@media (max-width: 900px) {
  header { padding: 16px 20px; flex-direction: column; align-items: flex-start; }
  main { padding: 20px; }
  .block2-grid { grid-template-columns: repeat(2, 1fr); }
  .results-panel { grid-template-columns: 1fr 1fr; }
  .score-display { flex-wrap: wrap; }
}

/* Pulsing badge for "aktives Halbjahr" */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.semester-active-header {
  color: var(--amber) !important;
  animation: pulse 2s infinite;
}

/* Action buttons */
.action-btn {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 1px;
  text-transform: uppercase;
  border: 1px solid var(--border2);
  background: var(--bg2);
  color: var(--text-dim);
  padding: 6px 14px;
  cursor: pointer;
  transition: all 0.15s;
}
.action-btn:hover { color: var(--amber); border-color: var(--amber-dim); background: var(--amber-glow); }
.action-btn.green:hover { color: #4ade80; border-color: #166534; background: rgba(34,197,94,0.08); }
.action-btn.red:hover { color: #fca5a5; border-color: rgba(239,68,68,0.4); background: rgba(239,68,68,0.08); }

/* Notenberater */
.notenberater-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 8px;
}

.nb-card {
  background: var(--bg2);
  border: 1px solid var(--border);
  padding: 14px 16px;
  position: relative;
  transition: border-color 0.2s;
}
.nb-card.achieved { border-color: #166534; background: rgba(34,197,94,0.06); }
.nb-card.possible { border-color: var(--border); }
.nb-card.impossible { opacity: 0.45; }
.nb-card.current { border-color: var(--amber); background: var(--amber-glow); }

.nb-note {
  font-family: var(--display);
  font-size: 32px;
  line-height: 1;
  color: var(--text-dim);
  margin-bottom: 6px;
}
.nb-card.achieved .nb-note { color: #4ade80; }
.nb-card.current .nb-note { color: var(--amber); }
.nb-card.impossible .nb-note { color: var(--text-muted); }

.nb-needed {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-muted);
  margin-bottom: 3px;
}

.nb-b2-needed {
  font-family: var(--mono);
  font-size: 12px;
  font-weight: 700;
  color: var(--text-dim);
}
.nb-card.achieved .nb-b2-needed { color: #4ade80; }
.nb-card.current .nb-b2-needed { color: var(--amber); }

.nb-per-fach {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--text-muted);
  margin-top: 2px;
}

.nb-status-dot {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: var(--text-muted);
}
.nb-card.achieved .nb-status-dot { background: #4ade80; }
.nb-card.current .nb-status-dot { background: var(--amber); animation: pulse 2s infinite; }
.nb-card.impossible .nb-status-dot { background: var(--red); }

.nb-bar {
  height: 3px;
  background: var(--bg3);
  border-radius: 2px;
  margin-top: 8px;
  overflow: hidden;
}
.nb-bar-fill {
  height: 100%;
  border-radius: 2px;
  background: var(--amber);
  transition: width 0.4s;
}
.nb-card.achieved .nb-bar-fill { background: #4ade80; }
.nb-card.impossible .nb-bar-fill { background: var(--red); }

.nb-b2-note {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--text-muted);
  margin-top: 5px;
}

/* Warning banner */
.warning-banner {
  display: none;
  background: rgba(239,68,68,0.1);
  border: 1px solid rgba(239,68,68,0.3);
  color: #fca5a5;
  font-family: var(--mono);
  font-size: 11px;
  padding: 10px 16px;
  letter-spacing: 0.5px;
}
.warning-banner.show { display: block; }
</style>
</head>
<body>

<header>
  <div class="header-left">
    <h1>ABITURNOTENRECHNER</h1>
    <p>Bayern G9 &bull; Technisches Gymnasium &bull; Q13/2 &bull; Stand 2026</p>
  </div>
  <div class="score-display">
    <div class="score-block">
      <div class="label">Block I</div>
      <div class="value" id="header-b1">—</div>
    </div>
    <div class="score-sep"></div>
    <div class="score-block">
      <div class="label">Block II</div>
      <div class="value" id="header-b2">—</div>
    </div>
    <div class="score-sep"></div>
